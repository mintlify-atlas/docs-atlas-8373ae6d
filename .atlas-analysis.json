  "keyFeatures": [
    "Real-time collaborative canvas with multiplayer cursors",
    "Multiple drawing tools (rectangles, ellipses, text, notes, pencil)",
    "Organization-based board management",
    "Board favorites and search functionality",
    "Authentication and user management with Clerk",
    "Undo/redo support with history tracking"
  ],
  "publicApiSurface": [
    "board.create - Create a new board",
    "board.remove - Delete a board",
    "board.update - Update board title",
    "board.favorite - Add board to favorites",
    "board.unFavorite - Remove board from favorites",
    "board.get - Get board by ID",
    "boards.get - Query boards with search and filters",
    "Canvas component - Main collaborative canvas",
    "useApiMutation - Hook for Convex mutations",
    "useDeleteLayers - Hook for deleting canvas layers",
    "useSelectionBounds - Hook for selection boundaries"
  ]
